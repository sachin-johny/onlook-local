# Example environment variables for Onlook
# Local mode for development (set to true to enable NodeFs provider)
NEXT_PUBLIC_ONLOOK_LOCAL_MODE=true
# Local preview URL for imported projects (used in local mode)
NEXT_PUBLIC_LOCAL_PREVIEW_URL=http://localhost:3001

# Add other required env vars below as needed for your setup
# ONLOOK_LOCAL_MODE=true
# CSB_API_KEY=your-csb-api-key
# SUPABASE_DATABASE_URL=your-supabase-url
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# ...
